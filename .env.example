# TTR Signal Detection System Environment Variables
# Copy this file to .env and fill in your actual values

# Application Environment
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Google Sheets API Configuration
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_CREDENTIALS_PATH=path/to/your/google/credentials.json
GOOGLE_SCOPES=https://www.googleapis.com/auth/spreadsheets

# Data Source API Keys (if needed)
TECHSNIF_API_KEY=your_techsnif_api_key_here
CRUNCHBASE_API_KEY=your_crunchbase_api_key_here

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com

# Slack Integration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#signals

# Database Configuration
DATABASE_URL=sqlite:///data/signals.db
# For PostgreSQL: postgresql://user:password@localhost:5432/ttr_signals

# TTR Contact Information
TTR_EMAIL=hello@tylerroessel.com
TTR_PHONE=your_phone_number_here
TTR_WEBSITE=https://tylerroessel.com

# Security
SECRET_KEY=your_secret_key_for_encryption_here

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=120
RATE_LIMIT_BURST=10

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_LOCATION=backups/
AWS_S3_BUCKET=your_backup_bucket_name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# Monitoring (Optional)
SENTRY_DSN=your_sentry_dsn_here
ANALYTICS_ENABLED=false

# Feature Flags
ENABLE_EMAIL_DISCOVERY=true
ENABLE_SOCIAL_ENRICHMENT=false
ENABLE_AI_SCORING=true
ENABLE_REAL_TIME_UPDATES=true